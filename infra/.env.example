# Local Compose secrets template.
# Copy to infra/.env and replace every placeholder locally.
# Do not commit infra/.env.

BILLING_SERVICE_CLIENT_SECRET=REPLACE_WITH_LOCAL_BILLING_SERVICE_CLIENT_SECRET
ADMIN_SERVICE_CLIENT_SECRET=REPLACE_WITH_LOCAL_ADMIN_SERVICE_CLIENT_SECRET
WEBHOOK_SECRET=REPLACE_WITH_LOCAL_WEBHOOK_HMAC_SECRET

# Keep this issuer value for the default local Docker Compose flow.
KEYCLOAK_ISSUER=http://localhost:8080/realms/topic10-sme-api

