{
  "id": "topic10-sme-api",
  "realm": "topic10-sme-api",
  "displayName": "SME API Security - Topic 10",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "failureFactor": 10,
  "waitIncrementSeconds": 60,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "maxDeltaTimeSeconds": 43200,
  "accessTokenLifespan": 300,
  "accessTokenLifespanForImplicitFlow": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "offlineSessionIdleTimeout": 2592000,
  "otpPolicyType": "totp",
  "otpPolicyAlgorithm": "HmacSHA1",
  "otpPolicyInitialCounter": 0,
  "otpPolicyDigits": 6,
  "otpPolicyLookAheadWindow": 1,
  "otpPolicyPeriod": 30,
  "requiredActions": [
    {
      "alias": "CONFIGURE_TOTP",
      "name": "Configure OTP",
      "providerId": "CONFIGURE_TOTP",
      "enabled": true,
      "defaultAction": false,
      "priority": 10,
      "config": {}
    },
    {
      "alias": "VERIFY_EMAIL",
      "name": "Verify Email",
      "providerId": "VERIFY_EMAIL",
      "enabled": true,
      "defaultAction": false,
      "priority": 50,
      "config": {}
    },
    {
      "alias": "UPDATE_PASSWORD",
      "name": "Update Password",
      "providerId": "UPDATE_PASSWORD",
      "enabled": true,
      "defaultAction": false,
      "priority": 30,
      "config": {}
    }
  ],
  "roles": {
    "realm": [
      {
        "id": "role-user",
        "name": "user",
        "description": "Standard user role",
        "composite": false,
        "clientRole": false
      },
      {
        "id": "role-admin",
        "name": "admin",
        "description": "Administrative role with elevated privileges",
        "composite": false,
        "clientRole": false
      },
      {
        "id": "role-billing-service",
        "name": "billing-service",
        "description": "Role for billing service-to-service communication",
        "composite": false,
        "clientRole": false
      },
      {
        "id": "role-internal-service",
        "name": "internal-service",
        "description": "Role for internal service-to-service communication",
        "composite": false,
        "clientRole": false
      }
    ]
  },
  "clients": [
    {
      "clientId": "sme-web-client",
      "name": "SME Web Client",
      "description": "Public client for user login via Authorization Code + PKCE",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:5173/*",
        "https://app.localhost/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:5173",
        "https://app.localhost"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    },
    {
      "clientId": "sme-service-client",
      "name": "SME Service Client",
      "description": "Confidential client for service-to-service (Client Credentials flow)",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect",
      "secret": "<redacted>",
      "attributes": {}
    }
  ],
  "users": [
    {
      "username": "alice",
      "email": "alice@example.local",
      "firstName": "Alice",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "alice-password-123",
          "temporary": false
        }
      ],
      "realmRoles": ["user"],
      "requiredActions": []
    },
    {
      "username": "bob",
      "email": "bob@example.local",
      "firstName": "Bob",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "bob-password-123",
          "temporary": false
        }
      ],
      "realmRoles": ["user"],
      "requiredActions": []
    },
    {
      "username": "admin01",
      "email": "admin01@example.local",
      "firstName": "Admin",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "admin-password-123",
          "temporary": false
        }
      ],
      "realmRoles": ["user", "admin"],
      "requiredActions": []
    }
  ],
  "scopeMappings": [],
  "clientScopeMappings": {}
}
