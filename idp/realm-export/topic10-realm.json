{
  "id": "topic10-sme-api",
  "realm": "topic10-sme-api",
  "displayName": "SME API Security - Topic 10",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "failureFactor": 10,
  "waitIncrementSeconds": 60,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "maxDeltaTimeSeconds": 43200,
  "accessTokenLifespan": 300,
  "accessTokenLifespanForImplicitFlow": 900,
  "revokeRefreshToken": true,
  "refreshTokenMaxReuse": 0,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "offlineSessionIdleTimeout": 2592000,
  "otpPolicyType": "totp",
  "otpPolicyAlgorithm": "HmacSHA1",
  "otpPolicyInitialCounter": 0,
  "otpPolicyDigits": 6,
  "otpPolicyLookAheadWindow": 1,
  "otpPolicyPeriod": 30,
  "requiredActions": [
    {
      "alias": "CONFIGURE_TOTP",
      "name": "Configure OTP",
      "providerId": "CONFIGURE_TOTP",
      "enabled": true,
      "defaultAction": false,
      "priority": 10,
      "config": {}
    },
    {
      "alias": "VERIFY_EMAIL",
      "name": "Verify Email",
      "providerId": "VERIFY_EMAIL",
      "enabled": true,
      "defaultAction": false,
      "priority": 50,
      "config": {}
    },
    {
      "alias": "UPDATE_PASSWORD",
      "name": "Update Password",
      "providerId": "UPDATE_PASSWORD",
      "enabled": true,
      "defaultAction": false,
      "priority": 30,
      "config": {}
    }
  ],
  "roles": {
    "realm": [
      {
        "id": "role-user",
        "name": "user",
        "description": "Standard user role",
        "composite": false,
        "clientRole": false
      },
      {
        "id": "role-admin",
        "name": "admin",
        "description": "Administrative role with elevated privileges",
        "composite": false,
        "clientRole": false
      },
      {
        "id": "role-billing-service",
        "name": "billing-service",
        "description": "Role for billing service-to-service communication",
        "composite": false,
        "clientRole": false
      },
      {
        "id": "role-internal-service",
        "name": "internal-service",
        "description": "Role for internal service-to-service communication",
        "composite": false,
        "clientRole": false
      },
      {
        "id": "role-order-ownership-read",
        "name": "order-ownership-read",
        "description": "Allows Billing service to verify order ownership through the Order internal API",
        "composite": false,
        "clientRole": false
      },
      {
        "id": "role-admin-maintenance",
        "name": "admin-maintenance",
        "description": "Allows Admin service maintenance automation through Client Credentials",
        "composite": false,
        "clientRole": false
      }
    ]
  },
  "clients": [
    {
      "clientId": "sme-web-client",
      "name": "SME Web Client",
      "description": "Public client for user login via Authorization Code + PKCE",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": [
        "https://localhost:3000/*",
        "https://localhost:3002/*",
        "https://localhost:5173/*",
        "https://app.localhost/*"
      ],
      "webOrigins": [
        "https://localhost:3000",
        "https://localhost:3002",
        "https://localhost:5173",
        "https://app.localhost"
      ],
      "protocolMappers": [
        {
          "name": "automation-owner-preferred-username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "automation_owner",
            "claim.name": "preferred_username",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "multivalued": "false"
          }
        },
        {
          "name": "automation-owner",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "automation_owner",
            "claim.name": "automation_owner",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "multivalued": "false"
          }
        },
        {
          "name": "automation-fixture",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "automation_fixture",
            "claim.name": "automation_fixture",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "multivalued": "false"
          }
        }
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    },
    {
      "clientId": "sme-lab-automation-client",
      "name": "SME Lab Automation Client",
      "description": "Public client reserved for local test automation password grant flows",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "automation-owner-preferred-username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "automation_owner",
            "claim.name": "preferred_username",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "multivalued": "false"
          }
        },
        {
          "name": "automation-owner",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "automation_owner",
            "claim.name": "automation_owner",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "multivalued": "false"
          }
        },
        {
          "name": "automation-fixture",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "automation_fixture",
            "claim.name": "automation_fixture",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "multivalued": "false"
          }
        }
      ]
    },
    {
      "clientId": "billing-service-client",
      "name": "Billing Service Client",
      "description": "Confidential client for Billing-to-Order ownership verification",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect",
      "secret": "${BILLING_SERVICE_CLIENT_SECRET}",
      "attributes": {
        "access.token.lifespan": "300"
      }
    },
    {
      "clientId": "admin-service-client",
      "name": "Admin Service Client",
      "description": "Confidential client for Admin maintenance automation",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect",
      "secret": "${ADMIN_SERVICE_CLIENT_SECRET}",
      "attributes": {
        "access.token.lifespan": "300"
      }
    }
  ],
